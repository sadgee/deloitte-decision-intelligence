# ---------------------------------------------------------------------------
# Input validation
# ---------------------------------------------------------------------------
def validate_inputs(data: dict) -> dict:
    """Clamp all inputs to realistic ranges to prevent nonsense model outputs."""
    data["VIX"]               = max(5,     min(80,   data.get("VIX", 20)))
    data["GDP_Growth"]        = max(-0.15, min(0.15, data.get("GDP_Growth", 0)))
    data["Unemployment"]      = max(0.01,  min(0.30, data.get("Unemployment", 0.05)))
    data["Interest_Rate"]     = max(0.0,   min(0.25, data.get("Interest_Rate", 0.05)))
    data["Operating_Margin"]  = max(-0.50, min(0.60, data.get("Operating_Margin", 0.10)))
    data["Investment_Cost"]   = max(1000,            data.get("Investment_Cost", 1_000_000))
    data["Baseline_Revenue"]  = max(1000,            data.get("Baseline_Revenue", 1_000_000))
    data["Time_Horizon_Months"] = max(1,  min(60,    data.get("Time_Horizon_Months", 12)))
    return data


# ---------------------------------------------------------------------------
# Confidence score
# ---------------------------------------------------------------------------
def calculate_confidence(signals: dict, input_dict: dict, has_news: bool) -> float:
    """
    Multi-factor confidence score reflecting how reliable the prediction is.

    Components:
        - Market stability (VIX weight 35%)   — calm markets increase confidence
        - Macro direction  (GDP weight 30%)   — clear GDP trend increases confidence
        - Signal strength  (AI  weight 20%)   — stronger news signals increase confidence
        - Base weight                   15%
        - Penalties: external risk -10%, no news input -8%
    """
    vix         = input_dict.get("VIX", 20)
    gdp         = input_dict.get("GDP_Growth", 0)
    sentiment   = signals.get("consumer_sentiment", 0)
    ext_risk    = signals.get("external_risk", 0)
    competition = signals.get("competitive_pressure", 0.5)

    vix_score       = max(0, 1 - (vix - 10) / 70)
    gdp_score       = 0.5 + min(0.5, max(-0.5, gdp * 5))
    signal_strength = abs(sentiment) * 0.3 + abs(competition - 0.5) * 2 * 0.2
    penalty         = ext_risk * 0.10 + (0.08 if not has_news else 0.0)

    score = vix_score * 0.35 + gdp_score * 0.30 + signal_strength * 0.20 + 0.15 - penalty
    return round(max(0.45, min(0.90, score)), 2)


# ---------------------------------------------------------------------------
# Verdict logic
# ---------------------------------------------------------------------------
def get_verdict(roi: float, risk_level: str) -> str:
    """
    Determine the investment verdict based on both ROI and risk level.
    A positive ROI with High risk does NOT automatically mean 'Proceed'.
    """
    if roi > 0.25 and risk_level in ["Low", "Medium"]:   return "Proceed"
    if roi > 0.10 and risk_level == "Low":                return "Proceed"
    if roi > 0    and risk_level in ["Low", "Medium"]:    return "Proceed with Caution"
    if roi > 0.15 and risk_level == "Medium-High":        return "Proceed with Caution"
    if roi > 0    and risk_level == "Medium-High":        return "Proceed with Caution"
    if roi > 0.20 and risk_level == "High":               return "Proceed with Caution"
    return "Do Not Proceed"

def get_verdict_tag(verdict: str) -> str:
    """Short action tag shown below the verdict label in the frontend."""
    if verdict == "Proceed":              return "FULL INVESTMENT"
    if verdict == "Proceed with Caution": return "PHASE INVESTMENT"
    return "HOLD DECISION"


# ---------------------------------------------------------------------------
# ROI breakdown
# ---------------------------------------------------------------------------
def calculate_roi_breakdown(input_dict: dict, base_roi: float) -> dict:
    """
    Build a transparent breakdown of how the final ROI was calculated.
    Each AI signal adjustment uses an explicit formula visible to the user.

    Adjustment formulas:
        sentiment_adj    = sentiment   * 0.18
        risk_adj         = ext_risk    * -0.12
        competition_adj  = (competition - 0.5) * -0.06
    """
    revenue     = input_dict.get("Baseline_Revenue", 1e8)
    margin      = input_dict.get("Operating_Margin", 0.10)
    investment  = input_dict.get("Investment_Cost", 1e6)
    sentiment   = input_dict.get("consumer_sentiment", 0)
    ext_risk    = input_dict.get("external_risk", 0)
    competition = input_dict.get("competitive_pressure", 0.5)

    s_adj = sentiment   *  0.18
    r_adj = ext_risk    * -0.12
    c_adj = (competition - 0.5) * -0.06

    adj_roi    = float(np.clip(base_roi + s_adj + r_adj + c_adj, -0.60, 0.80))
    rev_change = revenue * adj_roi * 0.4
    cost_change = (abs(rev_change) * (1 - margin) * 0.7 if rev_change > 0
                   else abs(rev_change) * 0.5)
    profit = rev_change - cost_change - investment

    return {
        "ml_base_roi_pct":            round(base_roi * 100, 1),
        "sentiment_adjustment_pct":   round(s_adj    * 100, 1),
        "risk_adjustment_pct":        round(r_adj    * 100, 1),
        "competition_adjustment_pct": round(c_adj    * 100, 1),
        "final_roi_pct":              round(adj_roi  * 100, 1),
        "revenue_change":             round(rev_change, 0),
        "cost_change":                round(cost_change, 0),
        "profit_change":              round(profit, 0),
        "investment":                 round(investment, 0),
    }


# ---------------------------------------------------------------------------
# Key factors
# ---------------------------------------------------------------------------
def get_key_factors(input_dict: dict, signals: dict) -> list:
    """
    Identify which variables had the most significant impact on the prediction.
    Returns plain-language explanations shown in the "Key Factors" panel.
    """
    factors      = []
    vix          = input_dict.get("VIX", 20)
    gdp          = input_dict.get("GDP_Growth", 0)
    sentiment    = signals.get("consumer_sentiment", 0)
    ext_risk     = signals.get("external_risk", 0)
    competition  = signals.get("competitive_pressure", 0.5)
    unemployment = input_dict.get("Unemployment", 0.05)

    if vix > 30:
        factors.append({"factor": "Market Volatility (VIX)", "value": f"{vix:.0f}", "impact": "negative",
            "reason": f"VIX at {vix:.0f} signals elevated uncertainty. Returns compress when VIX exceeds 25."})
    elif vix < 18:
        factors.append({"factor": "Market Volatility (VIX)", "value": f"{vix:.0f}", "impact": "positive",
            "reason": f"VIX at {vix:.0f} reflects calm conditions, supporting confidence in projected returns."})

    if gdp < -0.005:
        factors.append({"factor": "GDP Growth", "value": f"{gdp:.1%}", "impact": "negative",
            "reason": "Contracting economy reduces consumer demand and increases downside risk."})
    elif gdp > 0.02:
        factors.append({"factor": "GDP Growth", "value": f"{gdp:.1%}", "impact": "positive",
            "reason": "Positive GDP growth signals expanding demand, supporting revenue projections."})

    if sentiment < -0.3:
        factors.append({"factor": "Consumer Sentiment (AI)", "value": f"{sentiment:.2f}", "impact": "negative",
            "reason": "Negative sentiment from news reduces expected demand and conversion rates."})
    elif sentiment > 0.3:
        factors.append({"factor": "Consumer Sentiment (AI)", "value": f"{sentiment:.2f}", "impact": "positive",
            "reason": "Positive sentiment in news flow boosts demand projections."})

    if ext_risk == 1:
        factors.append({"factor": "External Risk (AI)", "value": "Flagged", "impact": "negative",
            "reason": "AI identified external risk signals in the news, reducing projected ROI by 12%."})

    if competition > 0.65:
        factors.append({"factor": "Competitive Pressure (AI)", "value": f"{competition:.2f}", "impact": "negative",
            "reason": "High competition detected in news. Compresses margin improvement potential."})

    if unemployment > 0.06:
        factors.append({"factor": "Unemployment Rate", "value": f"{unemployment:.1%}", "impact": "negative",
            "reason": "High unemployment signals weak consumer spending capacity."})

    return factors


# ---------------------------------------------------------------------------
# ML prediction
# ---------------------------------------------------------------------------
def run_prediction(data: dict, artifacts: dict) -> dict:
    """
    Run the ensemble ML model and compute the final ROI prediction.

    Steps:
        1. Label-encode categorical features using encoders saved during training
        2. Engineer derived features (must match training pipeline)
        3. Run ensemble model prediction
        4. Scale raw output to realistic ROI range (raw output inflated by synthetic data)
        5. Apply AI signal adjustments with explicit formulas
        6. Compute risk level and investment verdict
    """
    model    = artifacts["model"]
    encoders = artifacts["encoders"]
    features = artifacts["features"]
    processed = data.copy()

    # Encode categorical columns
    for col in ["Industry", "Company_Size", "Decision_Type", "Campaign_Intensity"]:
        if col in processed and col in encoders:
            try:
                processed[col] = encoders[col].transform([str(processed[col])])[0]
            except Exception:
                processed[col] = 0  # Default for unseen category

    # Derived features — must match the feature set used during model training
    processed["investment_ratio"]    = processed.get("Investment_Cost", 0) / (processed.get("Baseline_Revenue", 1) + 1)
    vix = processed.get("VIX", 20)
    processed["macro_stress"]        = (vix / 50 * 0.4
                                        + processed.get("Unemployment", 0.05) * 3 * 0.3
                                        + max(0, -processed.get("GDP_Growth", 0) * 10) * 0.3)
    processed["vol_vix"]             = processed.get("Vol_30D", 0.02) * vix
    processed["margin_x_investment"] = processed.get("Operating_Margin", 0.1) * processed.get("Investment_Cost", 0)

    # Raw model output
    raw_roi  = float(model.predict(np.array([[processed.get(f, 0) for f in features]]))[0])

    # Compress to realistic range — synthetic training data inflates raw outputs
    base_roi = float(np.clip(raw_roi * 0.06, -0.50, 0.80))

    # Apply AI signal adjustments
    sentiment   = data.get("consumer_sentiment", 0)
    ext_risk    = data.get("external_risk", 0)
    competition = data.get("competitive_pressure", 0.5)

    final_roi = float(np.clip(
        base_roi + sentiment * 0.18 - ext_risk * 0.12 - (competition - 0.5) * 0.06,
        -0.60, 0.80
    ))

    # Risk level derived from macro stress index and external risk flag
    risk_score = ext_risk * 0.4 + processed["macro_stress"] * 0.6
    risk_level = ("Low"         if risk_score < 0.25 else
                  "Medium"      if risk_score < 0.45 else
                  "Medium-High" if risk_score < 0.65 else "High")

    verdict = get_verdict(final_roi, risk_level)

    return {
        "roi":            final_roi,
        "risk_level":     risk_level,
        "recommendation": verdict,
        "verdict_tag":    get_verdict_tag(verdict),
        "base_roi":       base_roi,
    }


