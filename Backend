@app.post("/predict", response_model=PredictResponse)
def predict(req: PredictRequest):
    """
    Main prediction endpoint.

    Flow:
        1. Validate and clamp all inputs
        2. Extract AI signals from news text via Claude (Bedrock)
        3. Run ML ensemble prediction
        4. Calculate multi-factor confidence score
        5. Generate executive intelligence report via Claude (Bedrock)
        6. Build transparency data: ROI breakdown + key factors
        7. Look up industry benchmark for comparison
        8. Return full response to the React frontend
    """
    artifacts  = load_model()
    input_dict = validate_inputs(req.dict())

    has_news   = bool(req.news_text.strip())
    signals    = extract_signals(req.news_text, req.Industry, req.Decision_Type)
    full_input = {**input_dict, **signals}

    prediction  = run_prediction(full_input, artifacts)
    confidence  = calculate_confidence(signals, full_input, has_news)
    report      = generate_report(full_input, {**prediction, "confidence": confidence})
    breakdown   = calculate_roi_breakdown(full_input, prediction["base_roi"])
    key_factors = get_key_factors(input_dict, signals)

    decision_logic = DECISION_TYPE_LOGIC.get(req.Decision_Type, DECISION_TYPE_LOGIC["Marketing"])
    benchmark = INDUSTRY_BENCHMARKS.get(req.Industry, {}).get(
        req.Decision_Type,
        {"avg_roi": 0.15, "top_quartile": 0.30, "bottom_quartile": -0.05,
         "source": "Industry estimates based on public company disclosures"},
    )

    return PredictResponse(
        roi=prediction["roi"],
        confidence=confidence,
        risk_level=prediction["risk_level"],
        recommendation=prediction["recommendation"],
        verdict_tag=prediction["verdict_tag"],
        consumer_sentiment=signals["consumer_sentiment"],
        competitive_pressure=signals["competitive_pressure"],
        external_risk=signals["external_risk"],
        ai_report=report,
        decision_logic=decision_logic,
        roi_breakdown=breakdown,
        key_factors=key_factors,
        benchmark=benchmark,
    )
