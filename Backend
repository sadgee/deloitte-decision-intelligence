MODEL_ARTIFACTS = None

def load_model():
    """Load the trained ensemble model from S3 on first call, then cache in memory."""
    global MODEL_ARTIFACTS
    if MODEL_ARTIFACTS is None:
        s3  = boto3.client("s3", region_name="us-east-1")
        obj = s3.get_object(Bucket="deloitteml", Key="models/roi_model.pkl")
        MODEL_ARTIFACTS = joblib.load(io.BytesIO(obj["Body"].read()))
        print("Model loaded from S3")
    return MODEL_ARTIFACTS

@app.on_event("startup")
async def startup():
    """Pre-load the model on server startup to avoid cold-start latency."""
    load_model()


# ---------------------------------------------------------------------------
# Bedrock helper
# ---------------------------------------------------------------------------
def call_bedrock(prompt: str, max_tokens: int = 600) -> str:
    """Send a prompt to Claude via AWS Bedrock and return plain-text response."""
    response = bedrock.invoke_model(
        modelId=MODEL_ID,
        body=json.dumps({
            "anthropic_version": "bedrock-2023-05-31",
            "max_tokens": max_tokens,
            "messages": [{"role": "user", "content": prompt}],
        }),
        contentType="application/json",
        accept="application/json",
    )
    text = json.loads(response["body"].read())["content"][0]["text"]
    # Strip markdown symbols so the output renders cleanly in the frontend
    return text.replace("**", "").replace("##", "").replace("__", "").strip()


# ---------------------------------------------------------------------------
# AI signal extraction
# ---------------------------------------------------------------------------
def extract_signals(news_text: str, industry: str, decision_type: str) -> dict:
    """
    Use Claude to extract three quantitative signals from free-form market news.

    Returns a dict with:
        consumer_sentiment   float  -1 to +1  (negative = bearish, positive = bullish)
        competitive_pressure float   0 to  1  (higher = more competition)
        external_risk        int     0 or  1  (1 if macro/regulatory risk detected)
    """
    # Return neutral defaults when no news is provided
    if not news_text.strip():
        return {"consumer_sentiment": 0.0, "competitive_pressure": 0.5, "external_risk": 0}

    try:
        prompt = (
            f"Analyze this market information for a {industry} company considering {decision_type}.\n"
            f"Market info: {news_text}\n"
            f'Output ONLY this JSON, no other text:\n'
            f'{{"consumer_sentiment": <-1 to 1>, "competitive_pressure": <0 to 1>, "external_risk": <0 or 1>}}'
        )
        raw   = call_bedrock(prompt, max_tokens=200)
        match = re.search(r"\{.*\}", raw, re.DOTALL)
        if match:
            return json.loads(match.group())
    except Exception as e:
        print(f"Signal extraction error: {e}")

    return {"consumer_sentiment": 0.0, "competitive_pressure": 0.5, "external_risk": 0}


